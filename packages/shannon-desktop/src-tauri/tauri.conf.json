{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Shannon",
  "version": "0.1.0",
  "identifier": "com.shannon.desktop",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "Shannon",
        "url": "http://localhost:1948",
        "width": 1400,
        "height": 900,
        "visible": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
