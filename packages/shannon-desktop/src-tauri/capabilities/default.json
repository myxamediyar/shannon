{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": ["main", "shannon-print-helper"],
  "permissions": [
    "core:default",
    "core:webview:allow-print",
    "core:window:allow-create",
    "core:window:allow-close",
    "opener:default",
    "opener:allow-reveal-item-in-dir",
    {
      "identifier": "opener:allow-open-path",
      "allow": [
        { "path": "$HOME/.shannon/**" }
      ]
    },
    "http:default",
    "fs:default",
    "fs:allow-read-text-file",
    "fs:allow-write-text-file",
    "fs:allow-exists",
    "fs:allow-mkdir",
    "fs:allow-read-dir",
    "fs:allow-remove",
    "dialog:default",
    {
      "identifier": "fs:scope",
      "allow": [
        { "path": "$HOME/.shannon" },
        { "path": "$HOME/.shannon/**" }
      ]
    }
  ]
}
