    "@tiptap/react": "^3.22.3",
    "@tiptap/starter-kit": "^3.22.3",
    "@types/katex": "^0.16.8",
    "chart.js": "^4.4.6",
    "katex": "^0.16.42",
    "mathjs": "^15.2.0",
    "next": "^16.1.6",
    "pdfjs-dist": "^5.6.205",
    "rbush": "^4.0.1",
    "react": "^18",
    "react-chartjs-2": "^5.2.0",
    "react-dom": "^18",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "remark-mark-highlight": "^0.1.1"
