{
  "name": "tryshannon",
  "version": "0.1.7",
  "description": "A local-first, BYOK AI whiteboard. Infinite canvas for notes, chat, drawings, math, graphs, charts, tables, PDFs, and embeds.",
  "license": "Apache-2.0",
  "author": "myxamediyar",
  "homepage": "https://github.com/myxamediyar/shannon#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/myxamediyar/shannon.git"
  },
  "bugs": {
    "url": "https://github.com/myxamediyar/shannon/issues"
  },
  "keywords": [
    "shannon",
    "whiteboard",
    "canvas",
    "notes",
    "ai",
    "byok",
    "llm",
    "local-first",
    "nextjs"
  ],
  "engines": {
    "node": ">=20"
  },
  "bin": {
    "shannon": "bin/shannon.js"
  },
  "files": [
