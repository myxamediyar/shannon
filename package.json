{
  "name": "shannon-monorepo",
  "private": true,
  "version": "0.0.0",
  "description": "Monorepo for Shannon — the local-first AI whiteboard. See packages/shannon (npm) and packages/shannon-desktop (Tauri).",
  "license": "Apache-2.0",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev --workspace packages/shannon",
    "build": "npm run build --workspace packages/shannon",
    "tauri:dev": "npm run tauri --workspace packages/shannon-desktop -- dev",
    "tauri:build": "npm run tauri --workspace packages/shannon-desktop -- build"
  }
}
